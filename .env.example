BOT_TOKEN=your_telegram_bot_token_here
BOT_ADMIN_IDS=123456789,987654321

DATABASE_URL=postgresql://user:password@localhost:5432/vpn

THREEXUI_BASE_URL=https://your-3x-ui-panel-domain
THREEXUI_USERNAME=admin
THREEXUI_PASSWORD=strong_password
THREEXUI_INBOUND_ID=1
THREEXUI_TITLE=Default

# Хост и порт, к которым подключаются клиенты (в ссылке в конфиге). Если инбаунд в панели слушает 8443, а снаружи nginx отдаёт 443 — укажите сюда 443 и домен.
VLESS_SERVER=raccster.baselinux.net
VLESS_PORT=443

# Для multi-server режима можно вместо THREEXUI_* выше передать JSON с backend-ами.
# Если THREEXUI_BACKENDS_JSON пустой, проект продолжит использовать single-server конфиг выше.
# Пример:
# THREEXUI_BACKENDS_JSON=[{"key":"default","title":"NL-1","base_url":"https://panel-1.example.com","username":"admin","password":"secret","vless_server":"nl-1.example.com","vless_port":443,"inbound_id":1,"enabled":true},{"key":"de-1","title":"DE-1","base_url":"https://panel-2.example.com","username":"admin","password":"secret","vless_server":"de-1.example.com","vless_port":443,"inbound_id":1,"enabled":true}]
# THREEXUI_DEFAULT_KEY=default

# Публичный HTTPS-URL WebApp (Telegram принимает только https://). Можно указать с или без схемы.
# Пример: https://webapp.example.com  или  webapp.example.com
WEBAPP_URL=webapp.raccster.baselinux.net

# Порт HTTP-сервера WebApp (по умолчанию 8080). Если 8080 занят — например 8081
WEBAPP_PORT=8081