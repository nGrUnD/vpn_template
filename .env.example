BOT_TOKEN=your_telegram_bot_token_here
BOT_ADMIN_IDS=123456789,987654321

DATABASE_URL=postgresql://user:password@localhost:5432/vpn

THREEXUI_BASE_URL=https://your-3x-ui-panel-domain
THREEXUI_USERNAME=admin
THREEXUI_PASSWORD=strong_password

# Хост и порт, к которым подключаются клиенты (в ссылке в конфиге). Если инбаунд в панели слушает 8443, а снаружи nginx отдаёт 443 — укажите сюда 443 и домен.
VLESS_SERVER=raccster.baselinux.net
VLESS_PORT=443

# Публичный HTTPS-URL WebApp (Telegram принимает только https://). Можно указать с или без схемы.
# Пример: https://webapp.example.com  или  webapp.example.com
WEBAPP_URL=webapp.raccster.baselinux.net

# Порт HTTP-сервера WebApp (по умолчанию 8080). Если 8080 занят — например 8081
WEBAPP_PORT=8081